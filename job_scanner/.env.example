# Ollama (local)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b

# Resume path (relative to project root or absolute)
RESUME_PATH=files/Resume_Basavaraj_Jakkannavar_v1.pdf

# Matching threshold (0-100); jobs below this are skipped for apply
MIN_MATCH_SCORE=70

# Apply behavior: dry_run | assisted | auto
APPLY_MODE=dry_run

# Optional portal credentials (never commit real values)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# Browser: set false to see login/CAPTCHA during apply
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO_MS=100
